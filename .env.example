# Скопируй этот файл в .env и заполни значения
# Для генерации хешей паролей:
#   node -e "require('bcryptjs').hash('ВАШ_ПАРОЛЬ',10).then(console.log)"

JWT_SECRET=your-random-secret-at-least-32-chars
ADMIN_HASH=bcrypt-hash-of-admin-password
ANDREY_HASH=bcrypt-hash-of-andrey-password
PORT=3001

# MongoDB Atlas (для хостинга).
# Без этой строки приложение работает с локальными JSON файлами.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# HeySmart Mail (Gmail IMAP, required on Railway for mail polling).
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=heysmartmailbox@gmail.com
IMAP_PASSWORD=your-gmail-app-password
MAIL_POLL_INTERVAL_MS=12000
MAIL_TTL_SECONDS=2592000
